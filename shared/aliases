# ls - standard defaults
alias ls='ls --color=auto'
alias l='ls'
alias ll='ls -lh'
alias la='ls -A'
alias lla='ls -lAh'

# Override with eza if available
if command -v eza >/dev/null 2>&1; then
    alias ls='eza --group-directories-first'
    alias ll='eza --icons --group-directories-first -lh --git'
    alias la='eza --group-directories-first -A'
    alias lla='eza --icons --group-directories-first -lAh --git'
fi

# Navigation
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'

# Utilities
alias c='clear'
alias dfh='df -h'
alias duh='du -h -d 1'

# Project-specific
alias runai-portforward='make -C ~/Work/RunAI/runai_vscode_server/ port-forward-force'
