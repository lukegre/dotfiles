# If eza is available, use it for a more feature-rich ls experience
if command -v eza >/dev/null 2>&1; then
    alias ls='eza --group-directories-first'
    alias ll='ls --icons -lh --git'
# Fallback to regular ls with color if eza is not available
else
    alias ls='ls --color=auto'
    alias ll='ls -lh'
fi
# General ls aliases (but expanding the ls aliases above)
alias l='ls'
alias la='ls -A'
alias lla='ll -A'

# Navigation
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'

# SSH with X forwarding
alias ssh='ssh -X'

# Utilities
alias c='clear'
alias dfh='df -h'
alias duh='du -h -d 1'
